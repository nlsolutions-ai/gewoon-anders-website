{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/blog",
      "destination": "/informatie",
      "permanent": true
    },
    {
      "source": "/blog/:slug",
      "destination": "/informatie/:slug",
      "permanent": true
    }
  ]
}
